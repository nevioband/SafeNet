{
  "name": "safenet-smoke-tests",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Automatische Smoke-Tests fuer SafeNet Security",
  "scripts": {
    "start": "electron .",
    "dev": "node dev-server.js",
    "minify": "node build.js",
    "smoke": "playwright test tests/smoke.spec.js --project=chromium",
    "smoke:flows": "playwright test tests/flows.spec.js --project=chromium",
    "smoke:deep": "playwright test tests/flows.spec.js --project=chromium",
    "smoke:all": "playwright test tests --project=chromium --workers=1",
    "smoke:headed": "playwright test tests/smoke.spec.js --project=chromium --headed",
    "smoke:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "electron": "^42.1.0",
    "electron-packager": "^17.1.2",
    "purgecss": "^7.0.2",
    "terser": "^5.47.1"
  },
  "main": "main.js",
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "buffer-from": "^1.1.2",
    "commander": "^2.20.3",
    "docx": "^9.7.1",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "source-map": "^0.6.1",
    "source-map-support": "^0.5.21"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nevioband/SafeNet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nevioband/SafeNet/issues"
  },
  "homepage": "https://github.com/nevioband/SafeNet#readme"
}
