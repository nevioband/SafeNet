{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/pages/:path*",
      "destination": "/de/pages/:path*",
      "permanent": false
    },
    {
      "source": "/partials/:path*",
      "destination": "/de/partials/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/de", "destination": "/de/index.html" },
    { "source": "/en", "destination": "/en/index.html" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/de/(.*)", "dest": "/de/404.html", "status": 404 },
    { "src": "/(.*)", "dest": "/en/404.html", "status": 404 }
  ]
}